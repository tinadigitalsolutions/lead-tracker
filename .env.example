# Google OAuth client credentials
# Create an OAuth Client ID in Google Cloud Console.
# Use type "Desktop app" for easiest local testing.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Sheet where leads are stored.
# Create a spreadsheet with a sheet tab named: Leads
GOOGLE_SHEET_ID=

# Optional: default calendar id
# Change if you want a non-primary calendar to receive follow-ups.
GOOGLE_CALENDAR_ID=primary
